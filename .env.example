MARKET_SNIFFER_DB_PATH=runtime/market_sniffer.sqlite3
MARKET_SNIFFER_LOG_LEVEL=INFO

# Primary market data source. Either name is accepted.
MASSIVE_API_KEY=replace-with-local-key
POLYGON_API_KEY=replace-with-local-key

# Canonical macro source.
FRED_API_KEY=replace-with-local-key

# Yahoo is validation/enrichment now. Quote polling remains disabled by default.
YAHOO_ENABLED=false
YAHOO_QUOTES_ENABLED=false
